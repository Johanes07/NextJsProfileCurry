datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["appcompany"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model MenuItem {
  id        String   @id @default(cuid())
  name      String
  desc      String
  price     String
  category  String
  spice     String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model Promo {
  id        String   @id @default(cuid())
  type      String
  src       String
  tag       String
  title     String
  desc      String
  cta       String
  ctaLink   String
  badge     String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model SosmedPost {
  id        String   @id @default(cuid())
  type      String
  src       String
  link      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model JobPosition {
  id           String   @id @default(cuid())
  title        String
  dept         String
  type         String
  location     String
  desc         String
  requirements String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  @@schema("appcompany")
}

model SiteSettings {
  id           String   @id @default(cuid())
  siteName     String   @default("100Hours Curry")
  tagline      String?
  email        String?
  phone        String?
  address      String?
  logoUrl      String?
  facebookUrl  String?
  instagramUrl String?
  mapLat       Float?
  mapLng       Float?
  openHours    String?
  tiktokUrl    String?
  youtubeUrl   String?
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}


model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

// ─── HERO CONTENT ─────────────────────────────────────────
model HeroContent {
  id          String   @id @default(cuid())
  badgeText   String   @default("SIMMERED FOR 100 HOURS")
  headingLine1 String  @default("THE MOST")
  headingLine2 String  @default("LEGENDARY")
  headingLine3 String  @default("CURRY")
  subtitle    String   @default("Every bowl is a masterpiece.")
  estYear     String   @default("2020")
  stat1Value  String   @default("100")
  stat1Label  String   @default("Hours Cooked")
  stat1Suffix String   @default("hrs")
  stat2Value  String   @default("4.9")
  stat2Label  String   @default("Rating")
  stat2Suffix String   @default("★")
  stat3Value  String   @default("50K+")
  stat3Label  String   @default("Bowls Served")
  stat3Suffix String   @default("")
  updatedAt   DateTime @updatedAt
  @@schema("appcompany")
}

// ─── ADMIN NAV ITEMS ──────────────────────────────────────
model AdminNavItem {
  id        String         @id @default(cuid())
  label     String
  icon      String         // nama icon lucide, e.g. "LayoutDashboard"
  href      String?        // null = group header
  groupName String?        // nama group kalau ini adalah child
  order     Int            @default(0)
  isActive  Boolean        @default(true)
  children  AdminNavChild[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  @@schema("appcompany")
}

model AdminNavChild {
  id        String       @id @default(cuid())
  label     String
  icon      String
  href      String
  order     Int          @default(0)
  isActive  Boolean      @default(true)
  parentId  String
  parent    AdminNavItem @relation(fields: [parentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@schema("appcompany")
}

// ─── CTA SECTION ──────────────────────────────────────────
// Tambahkan model ini ke schema.prisma yang sudah ada
model CtaSection {
  id           String   @id @default(cuid())

  // Headline
  badge        String   @default("COME FIND US")
  headline1    String   @default("ONE BOWL.")
  headline2    String   @default("FOREVER.")
  description  String   @default("A curry so carefully crafted, one visit is all it takes to make you a regular.")

  // Contact
  address      String   @default("Jl. Kuliner No. 1, Jakarta Selatan")
  hours        String   @default("Open Daily: 11:00 AM – 10:00 PM")
  phone        String   @default("+62 21 1234 5678")
  buttonLabel  String   @default("Get Directions")

  // Feature cards (stored as JSON array)
  features     Json     @default("[]")

  updatedAt    DateTime @updatedAt

  @@schema("appcompany")
}

model AboutHeroContent {
  id           String   @id @default(cuid())
  badgeText    String   @default("OUR STORY")
  headingLine1 String   @default("ABOUT")
  headingLine2 String   @default("100HOURS")
  description  String   @default("Born from obsession. Driven by flavor. We believe the best things in life — and curry — cannot be rushed.")
  imageUrl     String?  @default("/images/MAINDISH/AI8.png")
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}
