datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["appcompany"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model MenuItem {
  id        String   @id @default(cuid())
  name      String
  desc      String
  price     String
  category  String
  spice     String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model Promo {
  id        String   @id @default(cuid())
  type      String
  src       String
  tag       String
  title     String
  desc      String
  cta       String
  ctaLink   String
  badge     String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model SosmedPost {
  id        String   @id @default(cuid())
  type      String
  src       String
  link      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@schema("appcompany")
}

model JobPosition {
  id           String   @id @default(cuid())
  title        String
  dept         String
  type         String
  location     String
  desc         String
  requirements String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  @@schema("appcompany")
}

model SiteSettings {
  id           String   @id @default(cuid())
  siteName     String   @default("100Hours Curry")
  tagline      String?
  email        String?
  phone        String?
  address      String?
  logoUrl      String?
  facebookUrl  String?
  instagramUrl String?
  mapLat       Float?
  mapLng       Float?
  openHours    String?
  tiktokUrl    String?
  youtubeUrl   String?
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}




// ─── HERO CONTENT ─────────────────────────────────────────
model HeroContent {
  id          String   @id @default(cuid())
  badgeText   String   @default("SIMMERED FOR 100 HOURS")
  headingLine1 String  @default("THE MOST")
  headingLine2 String  @default("LEGENDARY")
  headingLine3 String  @default("CURRY")
  subtitle    String   @default("Every bowl is a masterpiece.")
  estYear     String   @default("2020")
  stat1Value  String   @default("100")
  stat1Label  String   @default("Hours Cooked")
  stat1Suffix String   @default("hrs")
  stat2Value  String   @default("4.9")
  stat2Label  String   @default("Rating")
  stat2Suffix String   @default("★")
  stat3Value  String   @default("50K+")
  stat3Label  String   @default("Bowls Served")
  stat3Suffix String   @default("")
  updatedAt   DateTime @updatedAt
  @@schema("appcompany")
}

// ─── ADMIN NAV ITEMS ──────────────────────────────────────
model AdminNavItem {
  id        String         @id @default(cuid())
  label     String
  icon      String         // nama icon lucide, e.g. "LayoutDashboard"
  href      String?        // null = group header
  groupName String?        // nama group kalau ini adalah child
  order     Int            @default(0)
  isActive  Boolean        @default(true)
  children  AdminNavChild[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  @@schema("appcompany")
}

model AdminNavChild {
  id        String       @id @default(cuid())
  label     String
  icon      String
  href      String
  order     Int          @default(0)
  isActive  Boolean      @default(true)
  parentId  String
  parent    AdminNavItem @relation(fields: [parentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@schema("appcompany")
}

// ─── CTA SECTION ──────────────────────────────────────────
// Tambahkan model ini ke schema.prisma yang sudah ada
model CtaSection {
  id           String   @id @default(cuid())

  // Headline
  badge        String   @default("COME FIND US")
  headline1    String   @default("ONE BOWL.")
  headline2    String   @default("FOREVER.")
  description  String   @default("A curry so carefully crafted, one visit is all it takes to make you a regular.")

  // Contact
  address      String   @default("Jl. Kuliner No. 1, Jakarta Selatan")
  hours        String   @default("Open Daily: 11:00 AM – 10:00 PM")
  phone        String   @default("+62 21 1234 5678")
  buttonLabel  String   @default("Get Directions")

  // Feature cards (stored as JSON array)
  features     Json     @default("[]")

  updatedAt    DateTime @updatedAt

  @@schema("appcompany")
}

model AboutHeroContent {
  id           String   @id @default(cuid())
  badgeText    String   @default("OUR STORY")
  headingLine1 String   @default("ABOUT")
  headingLine2 String   @default("100HOURS")
  description  String   @default("Born from obsession. Driven by flavor. We believe the best things in life — and curry — cannot be rushed.")
  imageUrl     String?  @default("/images/MAINDISH/AI8.png")
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}



model OurStoryContent {
  id           String   @id @default(cuid())

  // Badge & Heading
  badge        String   @default("How It All Started")
  headingLine1 String   @default("FROM A HOME")
  headingLine2 String   @default("KITCHEN TO")
  headingLine3 String   @default("THE WORLD")

  // Body paragraphs
  paragraph1   String   @default("It started in 2020 when our founder spent an entire weekend perfecting his grandmother's curry recipe. After 100 hours of slow cooking, he discovered something magical — depth of flavor that no shortcut could ever replicate.")
  paragraph2   String   @default("What began as a passion project shared with friends quickly grew into Jakarta's most talked-about curry destination. Word spread not through ads, but through the irresistible aroma and unforgettable taste.")
  paragraph3   String   @default("Today, we still follow the same 100-hour process. No compromises. No shortcuts. Just pure, obsessive dedication to the perfect bowl of curry.")

  // Stats
  stat1Value   String   @default("2020")
  stat1Label   String   @default("Founded")
  stat2Value   String   @default("3")
  stat2Label   String   @default("Locations")
  stat3Value   String   @default("50K+")
  stat3Label   String   @default("Bowls Served")

  // Floating badge
  hoursValue   String   @default("100")
  hoursLabel1  String   @default("Hours of dedication")
  hoursLabel2  String   @default("in every single bowl")

  // Image
  imageUrl     String?  @default("/images/MAINDISH/AI1.png")

  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}


model OurValuesContent {
  id           String   @id @default(cuid())
  badge        String   @default("What We Stand For")
  headingLine1 String   @default("OUR")
  headingLine2 String   @default("VALUES")
  values       Json     @default("[]")
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}

model TeamSectionMeta {
  id              String   @id @default(cuid())
  badge           String   @default("The People Behind The Curry")
  headingLine1    String   @default("MEET THE")
  headingLine2    String   @default("TEAM")
  heroImage       String   @default("/images/chef.jpg")
  heroTagline1    String   @default("The People Who Make")
  heroTagline2    String   @default("Every Bowl Perfect")
  ctaTitle        String   @default("JOIN OUR TEAM")
  ctaDesc         String   @default("Passionate about food? We're always looking for talented people who share our obsession.")
  ctaButtonLabel  String   @default("Get In Touch")
  ctaButtonLink   String   @default("/contact")
  updatedAt       DateTime @updatedAt
  @@schema("appcompany")
}

model MenuHeroContent {
  id          String   @id @default(cuid())
  badgeText   String   @default("CRAFTED WITH OBSESSION")
  headingLine1 String  @default("OUR")
  headingLine2 String  @default("MENU")
  subtitle    String   @default("Every dish slow-cooked to perfection. Choose your curry, choose your adventure.")
  imageUrl    String?  @default("/images/MAINDISH/AI1.png")
  updatedAt   DateTime @updatedAt
  @@schema("appcompany")
}

model ContactHeroContent {
  id           String   @id @default(cuid())
  badgeText    String   @default("FIND US")
  headingLine1 String   @default("GET IN")
  headingLine2 String   @default("TOUCH")
  subtitle     String   @default("Have a question? Want to reserve a table? We would love to hear from you.")
  imageUrl     String?  @default("/images/MAINDISH/AI3.png")
  updatedAt    DateTime @updatedAt
  @@schema("appcompany")
}